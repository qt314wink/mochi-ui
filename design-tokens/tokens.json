{
  "$schema": "https://schemas.designtokens.org/format.json",
  "mochi-ui": {
    "version": "1.0.0",
    "description": "Mochi UI - Tactile Claymorphism Design System",

    "color": {
      "rainbow": {
        "mint-green": { "$type": "color", "$value": "#A3E635", "description": "Whimsical, lighthearted" },
        "baby-blue": { "$type": "color", "$value": "#7DD3FC" },
        "lavender": { "$type": "color", "$value": "#C084FC" },
        "peach": { "$type": "color", "$value": "#FB923C" }
      },
      "pink-red": {
        "blush-pink": { "$type": "color", "$value": "#FDA4AF", "description": "Calming, warm, romantic" },
        "soft-rose": { "$type": "color", "$value": "#FB7185" }
      },
      "blue": {
        "powder-blue": { "$type": "color", "$value": "#BAE6FD", "description": "Serene, fresh, clarity" },
        "sky-blue": { "$type": "color", "$value": "#38BDF8" }
      },
      "green": {
        "sage-green": { "$type": "color", "$value": "#86EFAC", "description": "Natural, soothing" },
        "mint-green": { "$type": "color", "$value": "#4ADE80" }
      },
      "neutrals": {
        "ivory": { "$type": "color", "$value": "#FEF3C7", "description": "Grounded, sophisticated" },
        "soft-taupe": { "$type": "color", "$value": "#D6D3D1" },
        "warm-white": { "$type": "color", "$value": "#FDF6E3" },
        "clay-white": { "$type": "color", "$value": "#F5F0E8" }
      },
      "dark": {
        "elevated-black": { "$type": "color", "$value": "#1A1A2E", "description": "Never pure black - preserves shadow contrast" },
        "deep-navy": { "$type": "color", "$value": "#16213E" },
        "soft-charcoal": { "$type": "color", "$value": "#2D2D3A" }
      },
      "semantic": {
        "background": { "$type": "color", "$value": "{color.neutrals.clay-white}" },
        "surface": { "$type": "color", "$value": "{color.neutrals.warm-white}" },
        "primary": { "$type": "color", "$value": "{color.rainbow.mint-green}" },
        "accent": { "$type": "color", "$value": "{color.blue.sky-blue}" },
        "text-primary": { "$type": "color", "$value": "#2C3E50" },
        "text-secondary": { "$type": "color", "$value": "#5D6D7E" }
      }
    },

    "shadow": {
      "matrix": {
        "layer-1-base": { 
          "$type": "shadow", 
          "$value": "none",
          "description": "Background color layer - bright pastel"
        },
        "layer-2-lift-sm": {
          "$type": "shadow",
          "$value": {
            "color": "rgba(0,0,0,0.1)",
            "offsetX": "4px",
            "offsetY": "4px",
            "blur": "8px",
            "spread": "0px"
          },
          "description": "Outset drop shadow for floating depth"
        },
        "layer-2-lift-md": {
          "$type": "shadow",
          "$value": {
            "color": "rgba(0,0,0,0.1)",
            "offsetX": "8px",
            "offsetY": "8px",
            "blur": "16px",
            "spread": "0px"
          }
        },
        "layer-2-lift-lg": {
          "$type": "shadow",
          "$value": {
            "color": "rgba(0,0,0,0.1)",
            "offsetX": "20px",
            "offsetY": "20px",
            "blur": "40px",
            "spread": "0px"
          }
        },
        "layer-3-volume": {
          "$type": "shadow",
          "$value": {
            "color": "rgba(0,0,0,0.05)",
            "offsetX": "-10px",
            "offsetY": "-10px",
            "blur": "20px",
            "spread": "0px",
            "inset": true
          },
          "description": "Darker inner shadow for 3D inflation"
        },
        "layer-4-reflection": {
          "$type": "shadow",
          "$value": {
            "color": "rgba(255,255,255,0.8)",
            "offsetX": "10px",
            "offsetY": "10px",
            "blur": "20px",
            "spread": "0px",
            "inset": true
          },
          "description": "Lighter inner shadow for light source"
        }
      },
      "composite": {
        "float": {
          "$type": "shadow",
          "$value": [
            "{shadow.matrix.layer-2-lift-md}",
            "{shadow.matrix.layer-3-volume}",
            "{shadow.matrix.layer-4-reflection}"
          ]
        },
        "pressed": {
          "$type": "shadow",
          "$value": [
            "{shadow.matrix.layer-3-volume}",
            {
              "color": "rgba(0,0,0,0.15)",
              "offsetX": "inset 0px",
              "offsetY": "4px",
              "blur": "8px",
              "spread": "0px",
              "inset": true
            }
          ]
        }
      }
    },

    "dimension": {
      "radius": {
        "clay": { "$type": "dimension", "$value": "50%", "description": "Pill/circular shape" },
        "bento": { "$type": "dimension", "$value": "24px", "description": "Bento grid cards" },
        "soft": { "$type": "dimension", "$value": "16px" },
        "button": { "$type": "dimension", "$value": "9999px", "description": "Full pill buttons" }
      },
      "spacing": {
        "xs": { "$type": "dimension", "$value": "4px" },
        "sm": { "$type": "dimension", "$value": "8px" },
        "md": { "$type": "dimension", "$value": "16px" },
        "lg": { "$type": "dimension", "$value": "24px" },
        "xl": { "$type": "dimension", "$value": "32px" },
        "xxl": { "$type": "dimension", "$value": "48px" },
        "button-padding-x": { "$type": "dimension", "$value": "3rem" },
        "button-padding-y": { "$type": "dimension", "$value": "1.5rem" }
      }
    },

    "duration": {
      "snappy": { "$type": "duration", "$value": "120ms" },
      "quick": { "$type": "duration", "$value": "200ms" },
      "smooth": { "$type": "duration", "$value": "300ms" },
      "spring": { "$type": "duration", "$value": "400ms" },
      "luxurious": { "$type": "duration", "$value": "800ms" }
    },

    "cubicBezier": {
      "clay-spring": {
        "$type": "cubicBezier",
        "$value": [0.34, 1.56, 0.64, 1],
        "description": "Elastic overshoot for clay press"
      },
      "clay-settle": {
        "$type": "cubicBezier",
        "$value": [0.39, 0.24, 0.3, 1],
        "description": "Smooth settling after bounce"
      },
      "clay-compress": {
        "$type": "cubicBezier",
        "$value": [0.4, 0, 0.2, 1],
        "description": "Quick compression on press"
      }
    },

    "spring": {
      "bounce": {
        "$type": "number",
        "$value": 40,
        "description": "0-100: How elastic the clay feels"
      },
      "perceptual-duration": {
        "$type": "duration",
        "$value": "400ms",
        "description": "How fast interaction resolves"
      },
      "tension": {
        "$type": "number",
        "$value": 300,
        "description": "Derived from bounce: 300 - (bounce * 2)"
      },
      "friction": {
        "$type": "number",
        "$value": 20,
        "description": "Derived from duration: 1000/duration"
      }
    },

    "haptic": {
      "soft-impact": {
        "$type": "string",
        "$value": "ImpactFeedbackStyle.Soft",
        "description": "Gentle press, high elasticity"
      },
      "granular-tick": {
        "$type": "string",
        "$value": "Segment_Frequent_Tick",
        "description": "Slider/chart granular scrolling"
      },
      "deep-compression": {
        "$type": "string",
        "$value": "Long_Press",
        "description": "Bento card deep press"
      }
    },

    "typography": {
      "font-family": {
        "$type": "fontFamily",
        "$value": ["Inter", "system-ui", "sans-serif"]
      },
      "heading-xl": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family}",
          "fontSize": "48px",
          "fontWeight": 700,
          "lineHeight": 1.1,
          "letterSpacing": "-0.02em"
        }
      },
      "heading-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family}",
          "fontSize": "32px",
          "fontWeight": 600,
          "lineHeight": 1.2,
          "letterSpacing": "-0.01em"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family}",
          "fontSize": "16px",
          "fontWeight": 400,
          "lineHeight": 1.6,
          "letterSpacing": "0"
        }
      }
    }
  }
}
