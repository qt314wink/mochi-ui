{
  "$schema": "https://design-tokens.github.io/format/schemas/dtcg.schema.json",
  "mochi": {
    "color": {
      "rainbow": {
        "mint": {
          "$type": "color",
          "$value": "#A3E635",
          "$description": "Whimsical and lighthearted"
        },
        "babyBlue": {
          "$type": "color",
          "$value": "#7DD3FC"
        },
        "lavender": {
          "$type": "color",
          "$value": "#C084FC"
        },
        "peach": {
          "$type": "color",
          "$value": "#FB923C"
        }
      },
      "pinkRed": {
        "blushPink": {
          "$type": "color",
          "$value": "#FDA4AF",
          "$description": "Calming, warm, romantic"
        },
        "softRose": {
          "$type": "color",
          "$value": "#FB7185"
        }
      },
      "blue": {
        "powder": {
          "$type": "color",
          "$value": "#BAE6FD",
          "$description": "Serene and fresh, ideal for clarity"
        },
        "sky": {
          "$type": "color",
          "$value": "#38BDF8"
        }
      },
      "green": {
        "sage": {
          "$type": "color",
          "$value": "#86EFAC",
          "$description": "Natural and soothing"
        },
        "mint": {
          "$type": "color",
          "$value": "#4ADE80"
        }
      },
      "neutrals": {
        "ivory": {
          "$type": "color",
          "$value": "#FEF3C7",
          "$description": "Grounded and sophisticated"
        },
        "softTaupe": {
          "$type": "color",
          "$value": "#D6D3D1"
        },
        "warmBeige": {
          "$type": "color",
          "$value": "#F5E6D3"
        }
      },
      "dark": {
        "elevated": {
          "$type": "color",
          "$value": "#1E1E2E",
          "$description": "Never pure black - preserves shadow contrast"
        },
        "surface": {
          "$type": "color",
          "$value": "#2D2D44"
        },
        "card": {
          "$type": "color",
          "$value": "#252538"
        }
      }
    },
    "shadow": {
      "lift": {
        "sm": {
          "$type": "shadow",
          "$value": {
            "color": "#0000001A",
            "offsetX": "0px",
            "offsetY": "4px",
            "blur": "8px",
            "spread": "0px"
          }
        },
        "md": {
          "$type": "shadow",
          "$value": {
            "color": "#0000001A",
            "offsetX": "0px",
            "offsetY": "8px",
            "blur": "16px",
            "spread": "0px"
          }
        },
        "lg": {
          "$type": "shadow",
          "$value": {
            "color": "#0000001A",
            "offsetX": "0px",
            "offsetY": "20px",
            "blur": "40px",
            "spread": "0px"
          }
        }
      },
      "volume": {
        "inset": {
          "$type": "shadow",
          "$value": {
            "color": "#0000000D",
            "offsetX": "-10px",
            "offsetY": "-10px",
            "blur": "20px",
            "spread": "0px"
          }
        }
      },
      "reflection": {
        "inset": {
          "$type": "shadow",
          "$value": {
            "color": "#FFFFFFCC",
            "offsetX": "10px",
            "offsetY": "10px",
            "blur": "20px",
            "spread": "0px"
          }
        }
      }
    },
    "radius": {
      "clay": {
        "$type": "dimension",
        "$value": "50%",
        "$description": "Maximum rounding for organic feel"
      },
      "bento": {
        "$type": "dimension",
        "$value": "24px"
      },
      "pill": {
        "$type": "dimension",
        "$value": "9999px"
      },
      "button": {
        "$type": "dimension",
        "$value": "20px"
      },
      "card": {
        "$type": "dimension",
        "$value": "28px"
      },
      "input": {
        "$type": "dimension",
        "$value": "16px"
      }
    },
    "spacing": {
      "xs": {
        "$type": "dimension",
        "$value": "4px"
      },
      "sm": {
        "$type": "dimension",
        "$value": "8px"
      },
      "md": {
        "$type": "dimension",
        "$value": "16px"
      },
      "lg": {
        "$type": "dimension",
        "$value": "24px"
      },
      "xl": {
        "$type": "dimension",
        "$value": "32px"
      },
      "xxl": {
        "$type": "dimension",
        "$value": "48px"
      }
    },
    "motion": {
      "spring": {
        "bounce": {
          "$type": "number",
          "$value": 0.4,
          "$description": "0-1: how elastic the clay feels"
        },
        "duration": {
          "$type": "duration",
          "$value": "300ms",
          "$description": "Perceptual duration - how fast interaction resolves"
        }
      },
      "easing": {
        "clay": {
          "$type": "cubicBezier",
          "$value": [
            0.34,
            1.56,
            0.64,
            1
          ]
        },
        "smooth": {
          "$type": "cubicBezier",
          "$value": [
            0.4,
            0,
            0.2,
            1
          ]
        },
        "bounce": {
          "$type": "cubicBezier",
          "$value": [
            0.68,
            -0.55,
            0.265,
            1.55
          ]
        }
      }
    },
    "typography": {
      "fontFamily": {
        "$type": "fontFamily",
        "$value": [
          "Inter",
          "system-ui",
          "sans-serif"
        ]
      },
      "heading": {
        "size": {
          "$type": "dimension",
          "$value": "32px"
        },
        "weight": {
          "$type": "fontWeight",
          "$value": 700
        },
        "lineHeight": {
          "$type": "number",
          "$value": 1.2
        }
      },
      "body": {
        "size": {
          "$type": "dimension",
          "$value": "16px"
        },
        "weight": {
          "$type": "fontWeight",
          "$value": 400
        },
        "lineHeight": {
          "$type": "number",
          "$value": 1.5
        }
      }
    }
  }
}