---
export interface Props {
  checked?: boolean;
  colorway?: 'mint' | 'blue' | 'pink' | 'lavender';
  size?: 'sm' | 'md' | 'lg';
  haptic?: boolean;
  disabled?: boolean;
  id?: string;
  name?: string;
  class?: string;
}

const {
  checked = false,
  colorway = 'mint',
  size = 'md',
  haptic = true,
  disabled = false,
  id,
  name,
  class: className = ''
} = Astro.props;

const colors = {
  mint: '#A3E635',
  blue: '#38BDF8',
  pink: '#FB7185',
  lavender: '#A78BFA'
};

const sizes = {
  sm: { width: '40px', height: '24px', knob: '18px' },
  md: { width: '56px', height: '32px', knob: '26px' },
  lg: { width: '72px', height: '40px', knob: '34px' }
};
---

<label 
  class={`clay-toggle clay-toggle--${size} ${disabled ? 'clay-toggle--disabled' : ''} ${className}`}
  style={`--toggle-color: ${colors[colorway]}; --toggle-width: ${sizes[size].width}; --toggle-height: ${sizes[size].height}; --knob-size: ${sizes[size].knob};`}
>
  <input 
    type="checkbox" 
    class="clay-toggle__input"
    checked={checked}
    disabled={disabled}
    id={id}
    name={name}
    data-haptic={haptic}
  />
  <span class="clay-toggle__track">
    <span class="clay-toggle__knob" aria-hidden="true">
      <span class="clay-toggle__knob-highlight"></span>
      <span class="clay-toggle__knob-shadow"></span>
    </span>
  </span>
  <span class="clay-toggle__label"><slot /></span>
</label>

<style lang="scss">
  @use "../../styles/tokens" as *;

  .clay-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-md);
    cursor: pointer;

    &--disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    &__input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;

      &:checked + .clay-toggle__track {
        background: var(--toggle-color);

        .clay-toggle__knob {
          transform: translateX(calc(var(--toggle-width) - var(--toggle-height)));

          &::after {
            // Squish effect on toggle
            animation: toggle-squish 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
          }
        }
      }

      &:focus-visible + .clay-toggle__track {
        outline: 2px solid var(--toggle-color);
        outline-offset: 2px;
      }
    }

    &__track {
      position: relative;
      width: var(--toggle-width);
      height: var(--toggle-height);
      border-radius: var(--radius-pill);
      background: var(--mochi-soft-taupe);

      // Deep recess shadow
      box-shadow: 
        inset 2px 2px 4px rgba(0,0,0,0.1),
        inset -2px -2px 4px rgba(255,255,255,0.8);

      transition: background 0.3s ease;
    }

    &__knob {
      position: absolute;
      top: calc((var(--toggle-height) - var(--knob-size)) / 2);
      left: calc((var(--toggle-height) - var(--knob-size)) / 2);
      width: var(--knob-size);
      height: var(--knob-size);
      border-radius: 50%;
      background: var(--mochi-warm-white);

      // Floating knob shadow
      box-shadow: 
        2px 2px 6px rgba(0,0,0,0.15),
        inset -2px -2px 4px rgba(0,0,0,0.05),
        inset 2px 2px 4px rgba(255,255,255,0.9);

      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);

      // 3D sphere effect
      &::before {
        content: '';
        position: absolute;
        top: 15%;
        left: 20%;
        width: 30%;
        height: 20%;
        border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(255,255,255,0.8) 0%, transparent 70%);
      }

      // Shadow layer for depth
      &::after {
        content: '';
        position: absolute;
        bottom: 10%;
        left: 15%;
        width: 70%;
        height: 30%;
        border-radius: 50%;
        background: radial-gradient(ellipse at center, rgba(0,0,0,0.1) 0%, transparent 70%);
        filter: blur(2px);
      }
    }

    &__label {
      font-weight: 500;
      color: var(--color-text);
      user-select: none;
    }
  }

  @keyframes toggle-squish {
    0% { transform: translateX(calc(var(--toggle-width) - var(--toggle-height))) scaleX(1); }
    40% { transform: translateX(calc(var(--toggle-width) - var(--toggle-height))) scaleX(1.3) scaleY(0.8); }
    70% { transform: translateX(calc(var(--toggle-width) - var(--toggle-height))) scaleX(0.9) scaleY(1.1); }
    100% { transform: translateX(calc(var(--toggle-width) - var(--toggle-height))) scaleX(1) scaleY(1); }
  }

  // Dark mode
  :global([data-theme="dark"]) {
    .clay-toggle {
      &__track {
        box-shadow: 
          inset 2px 2px 4px rgba(0,0,0,0.3),
          inset -2px -2px 4px rgba(255,255,255,0.05);
      }

      &__knob {
        background: var(--mochi-soft-charcoal);
        box-shadow: 
          2px 2px 6px rgba(0,0,0,0.3),
          inset -2px -2px 4px rgba(0,0,0,0.2),
          inset 2px 2px 4px rgba(255,255,255,0.1);
      }
    }
  }
</style>

<script>
  document.querySelectorAll('.clay-toggle__input').forEach(input => {
    input.addEventListener('change', () => {
      if (input.dataset.haptic === 'true' && 'vibrate' in navigator) {
        navigator.vibrate(input.checked ? [15, 30, 15] : 10);
      }

      // Trigger spring animation on knob
      const knob = input.closest('.clay-toggle')?.querySelector('.clay-toggle__knob');
      if (knob) {
        knob.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';

        // Add overshoot
        requestAnimationFrame(() => {
          const finalTransform = getComputedStyle(knob).transform;
          knob.style.transform = finalTransform + ' scale(1.1)';
          setTimeout(() => {
            knob.style.transform = finalTransform;
          }, 200);
        });
      }
    });
  });
</script>
