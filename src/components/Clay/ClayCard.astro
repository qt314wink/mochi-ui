---
export interface Props {
  variant?: 'default' | 'bento' | 'feature' | 'stat';
  colorway?: 'mint' | 'blue' | 'pink' | 'lavender' | 'peach' | 'neutral';
  elevation?: 'low' | 'medium' | 'high';
  tilt?: boolean;
  float?: boolean;
  interactive?: boolean;
  class?: string;
  href?: string;
}

const {
  variant = 'default',
  colorway = 'neutral',
  elevation = 'medium',
  tilt = true,
  float = false,
  interactive = true,
  class: className = '',
  href
} = Astro.props;

const colorways = {
  mint: 'linear-gradient(135deg, #A3E635 0%, #86EFAC 100%)',
  blue: 'linear-gradient(135deg, #7DD3FC 0%, #38BDF8 100%)',
  pink: 'linear-gradient(135deg, #FDA4AF 0%, #FB7185 100%)',
  lavender: 'linear-gradient(135deg, #C084FC 0%, #A78BFA 100%)',
  peach: 'linear-gradient(135deg, #FB923C 0%, #FDBA74 100%)',
  neutral: 'var(--color-surface)'
};

const elevations = {
  low: '4px 4px 8px',
  medium: '8px 8px 16px',
  high: '20px 20px 40px'
};

const Tag = href ? 'a' : 'div';
---

<Tag
  class={`clay-card clay-card--${variant} clay-card--${colorway} ${interactive ? 'clay-card--interactive' : ''} ${float ? 'clay-card--float' : ''} ${className}`}
  style={`
    --card-bg: ${colorways[colorway]};
    --card-elevation: ${elevations[elevation]};
  `}
  href={href}
  data-tilt={tilt}
  data-float={float}
>
  <div class="clay-card__content">
    <slot name="header" />
    <div class="clay-card__body">
      <slot />
    </div>
    <slot name="footer" />
  </div>

  <!-- Decorative clay highlight -->
  <div class="clay-card__highlight" aria-hidden="true"></div>
  <div class="clay-card__shadow-layer" aria-hidden="true"></div>
</Tag>

<style lang="scss">
  @use "../../styles/tokens" as *;

  .clay-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-bento);
    background: var(--card-bg);
    overflow: hidden;

    // 4-Layer Shadow Matrix
    box-shadow: 
      var(--card-elevation) rgba(0,0,0,0.1),
      inset -10px -10px 20px rgba(0,0,0,0.05),
      inset 10px 10px 20px rgba(255,255,255,0.8);

    transition: 
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease;

    // Preserve 3D for tilt
    transform-style: preserve-3d;
    perspective: 1000px;

    // Variants
    &--bento {
      aspect-ratio: 1;
      padding: var(--spacing-xl);
    }

    &--feature {
      grid-row: span 2;
      padding: var(--spacing-xxl);
    }

    &--stat {
      padding: var(--spacing-lg);
      text-align: center;
    }

    // Interactive states
    &--interactive {
      cursor: pointer;

      &:hover {
        transform: translateY(-8px) scale(1.01);
        box-shadow: 
          20px 20px 40px rgba(0,0,0,0.12),
          inset -10px -10px 20px rgba(0,0,0,0.05),
          inset 10px 10px 20px rgba(255,255,255,0.9);

        .clay-card__highlight {
          opacity: 0.6;
        }
      }

      &:active {
        transform: scale(0.98) translateY(0);
        box-shadow: 
          4px 4px 8px rgba(0,0,0,0.1),
          inset -12px -12px 24px rgba(0,0,0,0.08),
          inset 12px 12px 24px rgba(255,255,255,0.6);
        transition-duration: 0.1s;
      }
    }

    // Floating animation
    &--float {
      animation: clay-float 6s ease-in-out infinite;
    }

    // Content
    &__content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    &__body {
      flex: 1;
    }

    // Decorative layers
    &__highlight {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 50%;
      background: linear-gradient(
        180deg,
        rgba(255,255,255,0.4) 0%,
        transparent 100%
      );
      border-radius: var(--radius-bento) var(--radius-bento) 0 0;
      opacity: 0.3;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    &__shadow-layer {
      position: absolute;
      inset: 0;
      border-radius: inherit;
      box-shadow: inset 0 -4px 12px rgba(0,0,0,0.05);
      pointer-events: none;
    }
  }

  // Link styling
  a.clay-card {
    text-decoration: none;
    color: inherit;
  }

  // Dark mode
  :global([data-theme="dark"]) {
    .clay-card {
      box-shadow: 
        var(--card-elevation) rgba(0,0,0,0.3),
        inset -10px -10px 20px rgba(0,0,0,0.2),
        inset 10px 10px 20px rgba(255,255,255,0.05);

      &__highlight {
        background: linear-gradient(
          180deg,
          rgba(255,255,255,0.05) 0%,
          transparent 100%
        );
      }
    }
  }

  @keyframes clay-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-8px) rotate(0.3deg); }
    75% { transform: translateY(-4px) rotate(-0.3deg); }
  }
</style>

<script>
  // 3D Tilt Effect
  document.querySelectorAll('.clay-card[data-tilt="true"]').forEach(card => {
    const handleMouseMove = (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;

      card.style.transform = `
        perspective(1000px)
        rotateY(${x * 12}deg)
        rotateX(${-y * 12}deg)
        translateZ(20px)
        scale(1.02)
      `;

      // Dynamic shadow based on tilt
      const shadowX = x * 20;
      const shadowY = Math.abs(y) * 20 + 8;
      card.style.boxShadow = `
        ${shadowX}px ${shadowY}px ${shadowY * 2}px rgba(0,0,0,0.1),
        inset -10px -10px 20px rgba(0,0,0,0.05),
        inset 10px 10px 20px rgba(255,255,255,0.8)
      `;
    };

    const handleMouseLeave = () => {
      card.style.transform = 'perspective(1000px) rotateY(0) rotateX(0) translateZ(0) scale(1)';
      card.style.boxShadow = '';
      card.style.transition = 'transform 0.6s cubic-bezier(0.39, 0.24, 0.3, 1), box-shadow 0.3s ease';
    };

    const handleMouseEnter = () => {
      card.style.transition = 'transform 0.1s ease-out, box-shadow 0.1s ease';
    };

    card.addEventListener('mousemove', handleMouseMove);
    card.addEventListener('mouseleave', handleMouseLeave);
    card.addEventListener('mouseenter', handleMouseEnter);
  });

  // Ambient float with varying speeds for depth
  document.querySelectorAll('.clay-card--float').forEach((card, index) => {
    const delay = index * 0.5;
    const speed = 5 + Math.random() * 3;
    (card as HTMLElement).style.animationDelay = `${delay}s`;
    (card as HTMLElement).style.animationDuration = `${speed}s`;
  });
</script>
