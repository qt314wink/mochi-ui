---
export interface Props {
  min?: number;
  max?: number;
  value?: number;
  step?: number;
  colorway?: 'mint' | 'blue' | 'pink' | 'lavender' | 'peach';
  size?: 'sm' | 'md' | 'lg';
  showTicks?: boolean;
  tickFrequency?: number;
  haptic?: boolean;
  disabled?: boolean;
  id?: string;
  name?: string;
  class?: string;
}

const {
  min = 0,
  max = 100,
  value = 50,
  step = 1,
  colorway = 'mint',
  size = 'md',
  showTicks = true,
  tickFrequency = 10,
  haptic = true,
  disabled = false,
  id,
  name,
  class: className = ''
} = Astro.props;

const colors = {
  mint: '#A3E635',
  blue: '#38BDF8',
  pink: '#FB7185',
  lavender: '#A78BFA',
  peach: '#FB923C'
};

const tickCount = Math.floor((max - min) / tickFrequency) + 1;
---

<div 
  class={`clay-slider clay-slider--${size} ${disabled ? 'clay-slider--disabled' : ''} ${className}`}
  style={`--slider-color: ${colors[colorway]}; --slider-value: ${((value - min) / (max - min)) * 100}%;`}
  data-min={min}
  data-max={max}
  data-step={step}
  data-haptic={haptic}
>
  <div class="clay-slider__track-container">
    <!-- Deep recess track -->
    <div class="clay-slider__track">
      <div class="clay-slider__track-fill"></div>
    </div>

    <!-- Tactile ticks -->
    {showTicks && (
      <div class="clay-slider__ticks">
        {Array.from({ length: tickCount }, (_, i) => (
          <div 
            class="clay-slider__tick"
            style={`left: ${(i / (tickCount - 1)) * 100}%`}
            data-value={min + i * tickFrequency}
          />
        ))}
      </div>
    )}

    <!-- Tactile clay knob -->
    <div class="clay-slider__knob-container" style={`left: var(--slider-value)`}>
      <div class="clay-slider__knob">
        <div class="clay-slider__knob-sphere">
          <div class="clay-slider__knob-highlight"></div>
          <div class="clay-slider__knob-shadow"></div>
        </div>
        <div class="clay-slider__value-bubble">
          <span class="clay-slider__value-text">{value}</span>
        </div>
      </div>
    </div>
  </div>

  <input 
    type="range"
    class="clay-slider__input"
    min={min}
    max={max}
    value={value}
    step={step}
    disabled={disabled}
    id={id}
    name={name}
  />
</div>

<style lang="scss">
  @use "../../styles/tokens" as *;

  .clay-slider {
    position: relative;
    width: 100%;
    padding: var(--spacing-xl) 0;

    &--disabled {
      opacity: 0.5;
      pointer-events: none;
    }

    &__track-container {
      position: relative;
      height: 40px;
      display: flex;
      align-items: center;
    }

    &__track {
      position: relative;
      width: 100%;
      height: 12px;
      border-radius: var(--radius-pill);
      background: var(--mochi-soft-taupe);

      // Deep recess effect
      box-shadow: 
        inset 3px 3px 6px rgba(0,0,0,0.1),
        inset -3px -3px 6px rgba(255,255,255,0.8);

      overflow: hidden;
    }

    &__track-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: var(--slider-value);
      background: linear-gradient(90deg, var(--slider-color), lighten-mix(var(--slider-color), 20%));
      border-radius: inherit;

      // Inner glow
      box-shadow: inset 0 0 8px rgba(255,255,255,0.3);

      transition: width 0.1s ease;
    }

    &__ticks {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      pointer-events: none;
    }

    &__tick {
      position: absolute;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--mochi-soft-taupe);

      box-shadow: 
        inset 1px 1px 2px rgba(0,0,0,0.1),
        1px 1px 2px rgba(255,255,255,0.8);

      transition: transform 0.2s ease, background 0.2s ease;

      &.active {
        transform: translate(-50%, -50%) scale(1.5);
        background: var(--slider-color);
      }
    }

    &__knob-container {
      position: absolute;
      top: 50%;
      transform: translate(-50%, -50%);
      z-index: 2;

      transition: left 0.1s ease;
    }

    &__knob {
      position: relative;
      width: 32px;
      height: 32px;
      cursor: grab;

      &:active {
        cursor: grabbing;

        .clay-slider__knob-sphere {
          transform: scale(0.9);
          box-shadow: 
            2px 2px 4px rgba(0,0,0,0.1),
            inset -4px -4px 8px rgba(0,0,0,0.08),
            inset 4px 4px 8px rgba(255,255,255,0.6);
        }

        .clay-slider__value-bubble {
          opacity: 1;
          transform: translate(-50%, -140%) scale(1);
        }
      }
    }

    &__knob-sphere {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: var(--mochi-warm-white);

      // 3D sphere shadow
      box-shadow: 
        4px 4px 12px rgba(0,0,0,0.15),
        inset -3px -3px 6px rgba(0,0,0,0.05),
        inset 3px 3px 6px rgba(255,255,255,0.9);

      transition: transform 0.2s ease, box-shadow 0.2s ease;
      position: relative;
    }

    &__knob-highlight {
      position: absolute;
      top: 15%;
      left: 20%;
      width: 35%;
      height: 25%;
      border-radius: 50%;
      background: radial-gradient(ellipse at center, rgba(255,255,255,0.9) 0%, transparent 70%);
    }

    &__knob-shadow {
      position: absolute;
      bottom: 10%;
      left: 20%;
      width: 60%;
      height: 30%;
      border-radius: 50%;
      background: radial-gradient(ellipse at center, rgba(0,0,0,0.08) 0%, transparent 70%);
      filter: blur(2px);
    }

    &__value-bubble {
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translate(-50%, -100%) scale(0.8);
      padding: var(--spacing-sm) var(--spacing-md);
      background: var(--slider-color);
      border-radius: var(--radius-soft);

      // Floating bubble shadow
      box-shadow: 
        4px 4px 12px rgba(0,0,0,0.15),
        inset -2px -2px 4px rgba(0,0,0,0.05),
        inset 2px 2px 4px rgba(255,255,255,0.4);

      opacity: 0;
      transition: opacity 0.2s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      pointer-events: none;

      // Triangle pointer
      &::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 6px solid transparent;
        border-top-color: var(--slider-color);
      }
    }

    &__value-text {
      font-weight: 700;
      font-size: 14px;
      color: white;
      text-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    &__input {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      cursor: pointer;
      margin: 0;

      &::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 32px;
        height: 32px;
      }
    }
  }

  // Dark mode
  :global([data-theme="dark"]) {
    .clay-slider {
      &__track {
        box-shadow: 
          inset 3px 3px 6px rgba(0,0,0,0.3),
          inset -3px -3px 6px rgba(255,255,255,0.05);
      }

      &__knob-sphere {
        background: var(--mochi-soft-charcoal);
        box-shadow: 
          4px 4px 12px rgba(0,0,0,0.3),
          inset -3px -3px 6px rgba(0,0,0,0.2),
          inset 3px 3px 6px rgba(255,255,255,0.1);
      }
    }
  }

  @function lighten-mix($color, $percent) {
    @return mix(white, $color, $percent);
  }
</style>

<script>
  document.querySelectorAll('.clay-slider').forEach(slider => {
    const input = slider.querySelector('.clay-slider__input') as HTMLInputElement;
    const knob = slider.querySelector('.clay-slider__knob-container') as HTMLElement;
    const fill = slider.querySelector('.clay-slider__track-fill') as HTMLElement;
    const ticks = slider.querySelectorAll('.clay-slider__tick');
    const haptic = slider.dataset.haptic === 'true';

    const min = parseFloat(slider.dataset.min || '0');
    const max = parseFloat(slider.dataset.max || '100');
    const step = parseFloat(slider.dataset.step || '1');

    let lastTick = -1;

    const updateSlider = () => {
      const value = parseFloat(input.value);
      const percent = ((value - min) / (max - min)) * 100;

      slider.style.setProperty('--slider-value', `${percent}%`);
      knob.style.left = `${percent}%`;

      // Update value bubble
      const bubble = slider.querySelector('.clay-slider__value-text');
      if (bubble) bubble.textContent = String(Math.round(value));

      // Update active ticks
      ticks.forEach((tick, index) => {
        const tickValue = min + index * parseFloat(tick.dataset.value || '0');
        tick.classList.toggle('active', value >= tickValue);
      });

      // Haptic feedback on tick crossing
      if (haptic && 'vibrate' in navigator) {
        const currentTick = Math.floor(value / step);
        if (currentTick !== lastTick) {
          navigator.vibrate(3);
          lastTick = currentTick;
        }
      }
    };

    input.addEventListener('input', updateSlider);
    input.addEventListener('change', () => {
      // Spring settle on release
      knob.style.transition = 'left 0.4s cubic-bezier(0.39, 0.24, 0.3, 1)';
      setTimeout(() => {
        knob.style.transition = 'left 0.1s ease';
      }, 400);

      if (haptic && 'vibrate' in navigator) {
        navigator.vibrate([5, 20, 5]);
      }
    });

    // Initialize
    updateSlider();
  });
</script>
