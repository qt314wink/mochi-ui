---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Mochi UI is a claymorphism design system and React UI component library with spring physics, tactile feedback, and accessible design tokens. Built for modern product teams.",
  ogImage = "/assets/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://mochi-ui-two.vercel.app');
const ogImageURL   = new URL(ogImage, Astro.site || 'https://mochi-ui-two.vercel.app');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#C8F6D8" />
  <meta name="color-scheme" content="light dark" />

  <meta name="keywords" content="claymorphism design system, React UI component library, spring physics UI, tactile design system, accessible UI components, Figma design tokens, modern UI framework, soft UI design system, interactive component library, neumorphism alternative, React UI kit, design system for product teams" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:site_name"   content="Mochi UI" />
  <meta property="og:image"       content={ogImageURL} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"   content="Mochi UI — Claymorphism Design System" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageURL} />
  <meta name="twitter:image:alt"   content="Mochi UI — Claymorphism Design System" />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/tokens.css" />
  <link rel="stylesheet" href="/styles/clay.css" />

  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
