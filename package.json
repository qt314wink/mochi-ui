{
  "name": "@mochi-ui/react",
  "version": "0.1.0",
  "description": "Claymorphism design system — clay primitives, motion layer, theme system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/styles/tokens.css"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "build:lib": "tsup",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "tokens": "node scripts/build-tokens.cjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "motion": ">=11"
  },
  "peerDependenciesMeta": {
    "motion": { "optional": true }
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "claymorphism",
    "design-system",
    "mochi",
    "clay",
    "motion",
    "tokens"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qt314wink/mochi-ui"
  },
  "homepage": "https://qt314wink.github.io/mochi-ui",
  "devDependencies": {
    "@astrojs/react": "^4.3.0",
    "astro": "^5.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
